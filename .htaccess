<IfModule mod_rewrite.c>
    RewriteEngine On

    # Prevent viewing of directory listings
    Options -Indexes

    # Block access to sensitive files
    <FilesMatch "^\.env|composer\.json|composer\.lock|package\.json|package-lock\.json|artisan|phpunit\.xml|vite\.config\.js$">
        Order allow,deny
        Deny from all
    </FilesMatch>

    # Block access to sensitive directories
    RedirectMatch 404 ^/(app|bootstrap|config|database|resources|routes|storage|tests|vendor)($|/)

    # Forward all other requests to the public directory
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
